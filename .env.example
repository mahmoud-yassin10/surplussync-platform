# Root local development defaults for SurplusSync Plus.
# Copy to .env for local use. Do not commit .env.

# ML service
ML_SERVICE_URL=http://127.0.0.1:8000
ML_REQUEST_TIMEOUT_MS=2500
ALLOW_FORECAST_FALLBACK=true
ALLOW_DEMO_FIXTURE=true
ML_PORT=8000

# Copilot / AI assistant service
COPILOT_SERVICE_URL=http://127.0.0.1:3001
COPILOT_SERVICE_TOKEN=dev-local-copilot-token-change-me
COPILOT_REQUEST_TIMEOUT_MS=5000
COPILOT_ALLOW_FORECAST_FALLBACK=true
MAIN_APP_SERVICE_TOKEN=dev-local-main-app-token-change-me
COPILOT_PORT=3001
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
COPILOT_SESSION_TTL_SECONDS=86400

# Frontend
FRONTEND_PORT=3000

# Optional Gemini language generation.
# Without this key, deterministic fallback is used.
GEMINI_API_KEY=
