# HTTP port for the Copilot Lab server (1-65535).
PORT=3000

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Server-only ML service settings (never expose to client-side variables).
ML_SERVICE_URL="http://127.0.0.1:8000"
ML_REQUEST_TIMEOUT_MS=5000
ALLOW_COPILOT_FORECAST_FALLBACK=true

# Server-only shared secret for SurplusSync Plus → Copilot reconciliation (never expose to client).
MAIN_APP_SERVICE_TOKEN="CHANGE_ME"
